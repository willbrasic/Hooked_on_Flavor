#!/bin/sh


# --------------------------------------------------------------
# Job Name
# --------------------------------------------------------------

### Optional. Set the job name
#SBATCH --job-name=Dynamic_Mixture_Validation


# --------------------------------------------------------------
# Output
# --------------------------------------------------------------

### Slurm stdout/stderr - captures Julia startup errors, module load failures, etc.
#SBATCH --output=slurm_%j.out
#SBATCH --error=slurm_%j.err


# --------------------------------------------------------------
# Account and Notifications
# --------------------------------------------------------------

### REQUIRED. Specify the PI group for this job
#SBATCH --account=wildenbeest

### Optional. Request email when job begins and ends
### SBATCH --mail-type=BEGIN,END,FAIL

### Optional. Specify email address to use for notification
#SBATCH --mail-user=wbrasic@arizona.edu


# --------------------------------------------------------------
# Resources
# --------------------------------------------------------------

### REQUIRED. Set the partition for your job.
#SBATCH --partition=standard

### REQUIRED. Run on a single node with a single process.
#SBATCH --nodes=1
#SBATCH --ntasks=1

### REQUIRED. Number of CPU cores for Julia threading. 94 is max for Puma and 28 is max for Ocelote
#SBATCH --cpus-per-task=94

### REQUIRED. Memory per core (total = cpus-per-task × mem-per-cpu).
#SBATCH --mem-per-cpu=1gb

### REQUIRED. Specify the time required for this job, hhh:mm:ss
#SBATCH --time=001:00:00


# --------------------------------------------------------------
# Estimation Flags
# --------------------------------------------------------------

# Forward flags to Julia.
# Set at submission time (defaults apply if not provided).
#
# Flags:
#   BETA           (default: 1.0)    Present-bias β (must match the estimation run)
#   ESTIMATE_PSI_3 (default: false)  Validate ψ_3-estimated model (reads ψ_3 from θ_hat[27])
#   PSI_3          (default: 0.75)   Fixed ψ_3 value (ignored when ESTIMATE_PSI_3=true)
#
# Usage examples:
#   Base model (β=1.0, ψ_3=0.75 fixed):
#     sbatch 02_Validation_Mixture_Slurm.sb
#
#   Present-bias run (β=0.7):
#     BETA=0.7 sbatch 02_Validation_Mixture_Slurm.sb
#
#   Fixed ψ_3 = 0.50:
#     PSI_3=0.50 sbatch 02_Validation_Mixture_Slurm.sb
#
#   Estimated ψ_3 (reads from θ_hat[27]):
#     ESTIMATE_PSI_3=true sbatch 02_Validation_Mixture_Slurm.sb
export BETA=${BETA:-1.0}
export ESTIMATE_PSI_3=${ESTIMATE_PSI_3:-false}
export PSI_3=${PSI_3:-0.75}


# --------------------------------------------------------------
# Execution
# --------------------------------------------------------------

# Load Julia module
module load julia

# Set Julia threads for VFI parallelization over price states
export JULIA_NUM_THREADS=$SLURM_CPUS_PER_TASK

# Navigate to the script directory
cd /home/u2/wbrasic/4th_Year_Paper/Dynamic_Model/03_Validation_Mixture_V2

# Run script
julia 02_Validation_Mixture.jl
